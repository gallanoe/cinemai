# Copy to .env and fill in. The SERVER reads this file directly.
# Note: the `env` block in claude_desktop_config.json sets vars for `mcp-remote`,
# NOT for this server — the key must live here.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional
PORT=3000
CINEMAI_DEFAULT_MODEL=google/gemini-2.5-flash-image
CINEMAI_DATA_DIR=./data
